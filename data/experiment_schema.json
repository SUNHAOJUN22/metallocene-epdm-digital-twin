{
  "version": "1.0",
  "description": "Canonical experimental data schema for EPDM/EPM metallocene solution polymerization calibration.",
  "required_fields": [
    "run_id",
    "catalyst_id",
    "reactor_scale_L",
    "mode",
    "temperature_C",
    "pressure_MPa",
    "ethylene_feed",
    "propylene_feed",
    "enb_feed",
    "hydrogen_feed",
    "solvent",
    "AlTi_ratio",
    "BHT_ratio",
    "rpm",
    "residence_time_min",
    "polymer_g",
    "activity",
    "Mw",
    "PDI",
    "Mooney",
    "C2_wt",
    "C3_wt",
    "ENB_wt",
    "Tg_C",
    "Tm_C",
    "notes"
  ],
  "units": {
    "reactor_scale_L": "L",
    "temperature_C": "degC",
    "pressure_MPa": "MPa",
    "ethylene_feed": "g or kg/h depending on source context",
    "propylene_feed": "g or kg/h depending on source context",
    "enb_feed": "mL, g, or kg/h depending on source context",
    "hydrogen_feed": "g/h or initial charge equivalent",
    "AlTi_ratio": "mol Al per mol Ti",
    "BHT_ratio": "relative BHT/catalyst or engineering ratio",
    "rpm": "min^-1",
    "residence_time_min": "min",
    "polymer_g": "g",
    "activity": "engineering activity index",
    "Mw": "g/mol",
    "PDI": "Mw/Mn",
    "Mooney": "ML(1+4)",
    "C2_wt": "wt%",
    "C3_wt": "wt%",
    "ENB_wt": "wt%",
    "Tg_C": "degC",
    "Tm_C": "degC"
  },
  "numeric_bounds": {
    "reactor_scale_L": [0.01, 100000.0],
    "temperature_C": [0.0, 250.0],
    "pressure_MPa": [0.0, 20.0],
    "ethylene_feed": [0.0, 1000000.0],
    "propylene_feed": [0.0, 1000000.0],
    "enb_feed": [0.0, 1000000.0],
    "hydrogen_feed": [0.0, 1000000.0],
    "AlTi_ratio": [0.0, 100000.0],
    "BHT_ratio": [0.0, 10000.0],
    "rpm": [0.0, 5000.0],
    "residence_time_min": [0.0, 10000.0],
    "polymer_g": [0.0, 10000000.0],
    "activity": [0.0, 1000000000.0],
    "Mw": [1000.0, 10000000.0],
    "PDI": [1.0, 20.0],
    "Mooney": [0.1, 500.0],
    "C2_wt": [0.0, 100.0],
    "C3_wt": [0.0, 100.0],
    "ENB_wt": [0.0, 30.0],
    "Tg_C": [-150.0, 150.0],
    "Tm_C": [-100.0, 250.0]
  },
  "aliases": {
    "ethylene_g": "ethylene_feed",
    "propylene_g": "propylene_feed",
    "enb_ml": "enb_feed",
    "activity_1e7_g_mol_h": "activity",
    "mooney": "Mooney",
    "ep_ratio": "notes"
  }
}
