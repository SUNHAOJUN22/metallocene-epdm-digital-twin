{
  "version": "V4.3",
  "rules": [
    {
      "rule_id": "h2_mw_decreases",
      "description": "氢气增加时链转移增强，Mw应下降或不升高。",
      "module_id": "reactor_kinetics",
      "independent_variable": "hydrogen_g_h",
      "dependent_variable": "Mw",
      "expected_trend": "nonincreasing",
      "condition": "same feed, T, P and catalyst",
      "test_points": [0.1, 50.0],
      "tolerance": 1e-9,
      "rationale": "氢气作为链转移剂降低平均链长。",
      "severity": "error",
      "suggested_fix": "检查ktr_H2、液相H2浓度和Mw模型。"
    },
    {
      "rule_id": "h2_mooney_decreases",
      "description": "氢气增加时门尼应下降或不升高。",
      "module_id": "product_properties",
      "independent_variable": "hydrogen_g_h",
      "dependent_variable": "Mooney",
      "expected_trend": "nonincreasing",
      "condition": "same feed, T, P and catalyst",
      "test_points": [0.1, 50.0],
      "tolerance": 1e-9,
      "rationale": "门尼主要随Mw降低而降低。",
      "severity": "warning",
      "suggested_fix": "检查门尼回归系数与Mw输入。"
    },
    {
      "rule_id": "solids_viscosity_increases",
      "description": "固含量增加时胶液黏度应增加。",
      "module_id": "fluid_rheology_hydraulics",
      "independent_variable": "solids_wt",
      "dependent_variable": "dynamic_viscosity_Pa_s",
      "expected_trend": "increases",
      "condition": "same solvent, T and Mw",
      "test_points": [5.0, 20.0],
      "tolerance": 1e-9,
      "rationale": "聚合物体积分数升高导致溶液黏度指数升高。",
      "severity": "error",
      "suggested_fix": "检查A_mu/B_mu和固含量单位。"
    },
    {
      "rule_id": "temperature_viscosity_decreases",
      "description": "温度升高时胶液黏度应下降。",
      "module_id": "fluid_rheology_hydraulics",
      "independent_variable": "temperature_C",
      "dependent_variable": "dynamic_viscosity_Pa_s",
      "expected_trend": "decreases",
      "condition": "same solvent, solids and Mw",
      "test_points": [100.0, 130.0],
      "tolerance": 1e-9,
      "rationale": "Arrhenius型黏温关系通常随温度升高而降低。",
      "severity": "error",
      "suggested_fix": "检查E_mu符号和温度单位。"
    },
    {
      "rule_id": "mw_viscosity_increases",
      "description": "Mw增加时胶液黏度应增加。",
      "module_id": "fluid_rheology_hydraulics",
      "independent_variable": "Mw",
      "dependent_variable": "dynamic_viscosity_Pa_s",
      "expected_trend": "increases",
      "condition": "same solvent, T and solids",
      "test_points": [300000.0, 600000.0],
      "tolerance": 1e-9,
      "rationale": "链缠结和溶液增稠随分子量提高而增强。",
      "severity": "warning",
      "suggested_fix": "检查alpha_Mw和非牛顿模型耦合。"
    },
    {
      "rule_id": "pipe_diameter_drop_increases",
      "description": "管径减小时压降应增加。",
      "module_id": "fluid_rheology_hydraulics",
      "independent_variable": "pipe_diameter_m",
      "dependent_variable": "pressure_drop_kPa",
      "expected_trend": "decreases",
      "condition": "same density, viscosity, flow and length",
      "test_points": [0.025, 0.05],
      "tolerance": 1e-9,
      "rationale": "Darcy-Weisbach压降随L/D和速度平方升高。",
      "severity": "error",
      "suggested_fix": "检查流速、截面积和摩擦因子计算。"
    },
    {
      "rule_id": "flow_drop_increases",
      "description": "流量增加时压降应增加。",
      "module_id": "fluid_rheology_hydraulics",
      "independent_variable": "volumetric_flow_m3_h",
      "dependent_variable": "pressure_drop_kPa",
      "expected_trend": "increases",
      "condition": "same density, viscosity, diameter and length",
      "test_points": [1.0, 2.0],
      "tolerance": 1e-9,
      "rationale": "管内流速升高导致动压项升高。",
      "severity": "error",
      "suggested_fix": "检查流量单位m3/h到m3/s换算。"
    },
    {
      "rule_id": "conversion_heat_increases",
      "description": "单体消耗增加时聚合放热应增加。",
      "module_id": "heat_balance",
      "independent_variable": "consumed_mol_h",
      "dependent_variable": "Q_rxn_kJ_h",
      "expected_trend": "increases",
      "condition": "same heat of polymerization",
      "test_points": [1.0, 2.0],
      "tolerance": 1e-9,
      "rationale": "聚合热正比于各单体消耗摩尔数。",
      "severity": "error",
      "suggested_fix": "检查deltaH符号约定和Q_rxn正值输出。"
    },
    {
      "rule_id": "flash_pressure_vapor_increases",
      "description": "闪蒸压力降低时气相分率应增加或不降低。",
      "module_id": "thermo_flash",
      "independent_variable": "pressure_Pa",
      "dependent_variable": "vapor_fraction",
      "expected_trend": "nonincreasing",
      "condition": "same inlet and temperature",
      "test_points": [500000.0, 50000.0],
      "tolerance": 1e-9,
      "rationale": "低压使K值增大，轻组分更易进入气相。",
      "severity": "warning",
      "suggested_fix": "检查Wilson/PR/SRK K值和Rachford-Rice求解。"
    },
    {
      "rule_id": "polymer_stays_liquid",
      "description": "聚合物伪组分不应进入气相。",
      "module_id": "thermo_flash",
      "independent_variable": "flash",
      "dependent_variable": "polymer_vapor_mass",
      "expected_trend": "bounded",
      "condition": "all flash operations",
      "test_points": [0.0],
      "tolerance": 1e-12,
      "rationale": "EPDM聚合物在闪蒸模型中被定义为非挥发液相/固相伪组分。",
      "severity": "error",
      "suggested_fix": "检查Flash.calculate中聚合物留液逻辑。"
    },
    {
      "rule_id": "high_pressure_enb_not_raise",
      "description": "压力从0.7升至2.0 MPa时ENB引入不应异常升高。",
      "module_id": "reactor_kinetics",
      "independent_variable": "pressure_MPa",
      "dependent_variable": "ENB_wt",
      "expected_trend": "nonincreasing",
      "condition": "same feed, T and catalyst",
      "test_points": [0.7, 2.0],
      "tolerance": 1e-9,
      "rationale": "内置经验规律：低压约0.7MPa更利于ENB结合，高压降低ENB相对引入。",
      "severity": "warning",
      "suggested_fix": "检查beta_P压力修正。"
    },
    {
      "rule_id": "enb_feed_enb_wt_increases",
      "description": "ENB进料增加时产品ENB wt%应上升。",
      "module_id": "reactor_kinetics",
      "independent_variable": "enb_kg_h",
      "dependent_variable": "ENB_wt",
      "expected_trend": "increases",
      "condition": "same E/P, T, P and catalyst",
      "test_points": [1.0, 8.0],
      "tolerance": 1e-9,
      "rationale": "ENB加入量升高时产品ENB含量近似上升。",
      "severity": "warning",
      "suggested_fix": "检查ENB浓度、竞争插入和转化率模型。"
    },
    {
      "rule_id": "low_alti_activity_drops",
      "description": "Al/Ti过低时活性或产率应下降。",
      "module_id": "reactor_kinetics",
      "independent_variable": "AlTi_ratio",
      "dependent_variable": "polymer_kg_h",
      "expected_trend": "increases",
      "condition": "compare low vs normal Al/Ti",
      "test_points": [200.0, 1000.0],
      "tolerance": 1e-9,
      "rationale": "MAO活化因子随Al/Ti从低值提高而上升并趋于平台。",
      "severity": "warning",
      "suggested_fix": "检查f_AlTi = AlTi/(K_Al+AlTi)。"
    },
    {
      "rule_id": "bht_activity_nonnegative",
      "description": "BHT修正不能导致负活性或负产率。",
      "module_id": "reactor_kinetics",
      "independent_variable": "BHT_ratio",
      "dependent_variable": "polymer_kg_h",
      "expected_trend": "bounded",
      "condition": "BHT in engineering range",
      "test_points": [0.0, 1.0],
      "tolerance": 0.0,
      "rationale": "助剂修正只允许降低/提高有效活性，不允许负活性。",
      "severity": "error",
      "suggested_fix": "检查activation_factor和positive保护。"
    },
    {
      "rule_id": "product_composition_100",
      "description": "产品C2+C3+ENB应接近100 wt%。",
      "module_id": "product_properties",
      "independent_variable": "composition",
      "dependent_variable": "sum_wt",
      "expected_trend": "bounded",
      "condition": "all polymer products",
      "test_points": [100.0],
      "tolerance": 0.5,
      "rationale": "聚合段质量分数必须归一化。",
      "severity": "error",
      "suggested_fix": "检查segment balance和composition normalization。"
    }
  ]
}
