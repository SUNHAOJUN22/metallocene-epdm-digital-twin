      "equation_id": "arrhenius_rate_constant",
      "module_id": "reactor_kinetics",
      "display_name": "Arrhenius apparent rate constant",
      "formula_text": "k_i(T)=k_i_ref*exp[-Ea_i/R*(1/T-1/T_ref)]",
      "variables": [
        "k_i",
        "k_i_ref",
        "Ea_i",
        "R",
        "T",
        "T_ref"
      ],
      "variable_units": {
        "k_i": "L/mol/h",
        "k_i_ref": "L/mol/h",
        "Ea_i": "J/mol",
        "R": "J/mol/K",
        "T": "K",
        "T_ref": "K"
      },
      "output_unit": "L/mol/h",
      "assumptions": "Apparent liquid-phase metallocene insertion rate; parameters require local calibration.",
      "validity_range": "R&D screening near 60-180 degC",
      "dimensional_check": "Ea/R*(1/T) is dimensionless",
      "fallback": "Exponent is bounded; non-finite values fall back to finite apparent constants.",
      "references_or_origin": "V1-V4 internal apparent kinetics",
      "implementation_function": "epdm_sim.kinetics.arrhenius",
      "input_units": {
        "k_i": "L/mol/h",
        "k_i_ref": "L/mol/h",
        "Ea_i": "J/mol",
        "R": "J/mol/K",
        "T": "K",
        "T_ref": "K"
      },
      "expected_trends": "finite bounded output under validity range",
      "benchmark_id": "arrhenius_rate_ratio",
      "fallback_policy": "Exponent is bounded; non-finite values fall back to finite apparent constants.",
      "residual_id": "arrhenius_rate_constant",
      "dimensional_signature": "Ea/R*(1/T) is dimensionless"
    },
